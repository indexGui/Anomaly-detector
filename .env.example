# Telegram Bot API credentials
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Enable/disable Telegram alerts (true/false)
TELEGRAM_ENABLED=true

# Engine scan interval in seconds
SCAN_INTERVAL_SECONDS=60

# Per-symbol cooldown in seconds (prevents duplicate alerts)
COOLDOWN_SECONDS=300

# Enable CSV logging of alerts (true/false)
CSV_LOG_ENABLED=false
CSV_LOG_PATH=alerts.csv
